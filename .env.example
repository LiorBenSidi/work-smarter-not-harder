# Copy to `.env` (NEVER commit `.env` — it's gitignored). docker-compose reads these.
SECRET_KEY=dev-secret-change-me
FLASK_DEBUG=0
TESTING=0
# Set to 1 in production (HTTPS) so the session cookie is marked Secure; 0 for local HTTP / dev.
SESSION_COOKIE_SECURE=0
# MONGO_URI and AI_URL are set on the internal Docker network in docker-compose.yml;
# override here only if you need to point elsewhere.
# Logging (Week 9 / Lab 9.1): ENABLE_LOGGING=0 turns logging off; LOG_LEVEL is DEBUG/INFO/WARNING/...;
# LOG_FILE is the in-container RotatingFileHandler path (persisted to the web-logs volume).
ENABLE_LOGGING=1
LOG_LEVEL=INFO
LOG_FILE=/app/logs/web.log
