# Copy to `.env` (NEVER commit `.env` — it's gitignored). docker-compose reads these.
SECRET_KEY=dev-secret-change-me
FLASK_DEBUG=0
TESTING=0
# Set to 1 in production (HTTPS) so the session cookie is marked Secure; 0 for local HTTP / dev.
SESSION_COOKIE_SECURE=0
# MONGO_URI and AI_URL are set on the internal Docker network in docker-compose.yml;
# override here only if you need to point elsewhere.
# --- MongoDB auth (production / Azure) ---
# Local dev: leave BOTH blank -> the db container runs without auth. To ENABLE auth:
#   1. set MONGO_USER + MONGO_PASSWORD (the db creates a root user), AND
#   2. point MONGO_URI at them with authSource=admin (below). If you set the creds but NOT MONGO_URI,
#      every request fails auth at runtime (not at boot). For real prod, make a least-privilege app user.
#   NOTE: mongo creates the root user only on a FRESH volume (first init) — turning auth on for an
#   existing mongo-data volume has NO effect; recreate the volume or add the user via db.createUser.
# MONGO_USER=appuser
# MONGO_PASSWORD=change-me-strong
# MONGO_URI=mongodb://appuser:change-me-strong@db:27017/worksmarter?authSource=admin
# Logging (Week 9 / Lab 9.1): ENABLE_LOGGING=0 turns logging off; LOG_LEVEL is DEBUG/INFO/WARNING/...;
# LOG_FILE is the in-container RotatingFileHandler path (persisted to the web-logs volume).
ENABLE_LOGGING=1
LOG_LEVEL=INFO
LOG_FILE=/app/logs/web.log
# --- Email (2-step login OTP + password reset) ---
# Leave SMTP_HOST blank -> the "log" backend: the OTP / reset link is written to the app log (no creds,
# nothing leaves the box) — fine for dev / demo. To send REAL mail, set a relay (e.g. free Brevo):
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USER=your-brevo-login
# SMTP_PASS=your-brevo-smtp-key
# MAIL_FROM=Work Smarter <no-reply@yourdomain>
# APP_BASE_URL is the public origin used to build the reset link in emails (set your domain in prod).
APP_BASE_URL=http://localhost:8000
# 2-step verification: OTP_ENABLED=1 emails a login code every login; set 0 to disable 2FA.
# The code expires after OTP_TTL_SECONDS and locks out after OTP_MAX_ATTEMPTS wrong tries.
# "Remember this browser" (opt-in per login) keeps a browser trusted for REMEMBER_COOKIE_MAX_AGE
# seconds (skips OTP); a password change or logout revokes it early.
OTP_ENABLED=1
OTP_TTL_SECONDS=600
OTP_MAX_ATTEMPTS=5
REMEMBER_COOKIE_MAX_AGE=2592000
# Verify the email at signup: 1 emails a code and creates the account only after it's confirmed
# (blocks fake / someone else's address); 0 creates the account immediately. Uses OTP_TTL/ATTEMPTS.
REGISTER_VERIFY_EMAIL=1
