# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Virtual envs
.venv/
venv/
env/
ENV/

# Secrets / local config — commit .env.example, never .env
.env
.env.*
!.env.example
*.key
*.pem
prod.env          # rendered by CI at deploy time from GitHub secrets — must never be committed
*_deploy          # the SSH deploy private key (assignment §3.1) — public .pub is fine, private never
id_ed25519*

# Large data + trained artifacts (bake the model into the image; keep big data out of git)
data/
datasets/
*.csv
*.parquet
*.h5
# If the trained Random Forest must ship in the image, force-add it: git add -f ai/model.pkl
*.pkl
*.joblib

# Frontend (if any)
node_modules/
dist/
build/

# Personal per-developer AI instructions — never commit (team CLAUDE.md is shared)
CLAUDE.local.md

# OS / editor junk
.DS_Store
Thumbs.db
.idea/
.vscode/
.claude/
*.swp

# Personal PERSON3 action plan — never commit (working doc, like CLAUDE.local.md)
PERSON3_PLAN.md
