# Caddy config for the Azure VM (assignment R10).
# {$SITE_ADDRESS} is read from the environment (set in docker-compose.prod.yml -> the VM's .env, = the FQDN).
# For that one hostname Caddy automatically:
#   - obtains a Let's Encrypt certificate on first boot (ACME HTTP-01 over port 80),   -> R10.2
#   - renews it before expiry with no cron/timer to maintain,                          -> R10.3
#   - redirects all plain HTTP to HTTPS.                                               -> R10.4
# reverse_proxy forwards the decrypted request to the internal web container on 5000
# (gunicorn stays on plain HTTP behind the proxy — the pattern the assignment's R10 note requires).
{$SITE_ADDRESS} {
	# Security headers (defence in depth; the app is HTTPS-only behind this proxy):
	#   HSTS         -> force HTTPS for a year (browsers refuse plain HTTP to this host),
	#   nosniff      -> no MIME-type sniffing (blocks content-type confusion),
	#   frame denial -> no framing of the app (clickjacking) — X-Frame-Options for old UAs + CSP for new,
	#   Referrer     -> don't leak full URLs cross-origin,
	#   -Server      -> drop the "Server: Caddy" banner (less version fingerprinting).
	# No script/style CSP directives: the SPA is intentionally inline-heavy, so a strict CSP would break it;
	# frame-ancestors is the clickjacking control and does not touch inline scripts.
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Content-Security-Policy "frame-ancestors 'none'"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}
	reverse_proxy web:5000
}
